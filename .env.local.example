AI_GATEWAY_API_KEY=

# Local Supabase. Run `pnpm db:start` then `pnpm db:status` and copy the values:
#   API URL  -> SUPABASE_URL
#   anon key -> SUPABASE_ANON_KEY   (local dev key; safe to keep local)
# For a hosted project, copy these from the Supabase dashboard instead.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=

# Direct Postgres connection used by bulk ingest + the eval harness (postgres.js).
# For local Supabase this is the superuser DSN printed by `supabase status`.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
